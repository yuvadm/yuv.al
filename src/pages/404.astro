---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist. This is a 404 error page on Yuval Adam's website.">
	<main class="page-main page-main--center">
		<div class="not-found">
			<h1 class="not-found__code">404</h1>
			<p class="not-found__title">Page Not Found</p>
			<p class="not-found__text">The page you're looking for doesn't exist.</p>
			<a href="/" class="not-found__back">← Back to home</a>
		</div>
	</main>
</Layout>
