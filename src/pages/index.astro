---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const homepage = (await getEntry("pages", "home"))!;
const { title, subtitle } = homepage.data;
const { Content } = await homepage.render();
---

<Layout description="Software engineer, entrepreneur, and technology enthusiast. Working on Namekit, experimenting with agentic coding, and sharing insights about modern web development.">
	<main class="max-w-2xl mx-auto px-6 pb-16">
		<p class="text-xl mb-8 text-gray-600">{subtitle}</p>
		<div class="space-y-6 mb-16 prose prose-lg prose-a:text-brand-primary prose-a:no-underline prose-a:hover:underline">
			<Content />
		</div>
	</main>
</Layout>
