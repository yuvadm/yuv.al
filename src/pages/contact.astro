---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const contact = (await getEntry("pages", "contact"))!;
const { title } = contact.data;
const { Content } = await contact.render();
---

<Layout title={title} description="How to get in touch with Yuval Adam.">
	<main class="page-main page-main--prose">
		<div class="prose prose-lg prose-a:text-brand-primary prose-a:no-underline prose-a:hover:underline">
			<Content />
		</div>
	</main>
</Layout>
