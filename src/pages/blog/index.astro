---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout
  title="Blog"
  description="Technical articles and insights about software development, web technologies, and programming. Sharing knowledge on modern frameworks, tools, and best practices."
>
  <main class="page-main page-main--list">
    <div class="blog-list">
      {
        sortedPosts.map((post) => (
          <article class="blog-list__item">
            <div class="blog-list__row">
              <h2 class="blog-list__title">
                <a
                  href={`/blog/${post.slug}/`}
                  class="hover:text-brand-primary"
                >
                  {post.data.title}
                </a>
              </h2>
              <time datetime={post.data.date} class="blog-list__date">
                {new Date(post.data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</Layout>
