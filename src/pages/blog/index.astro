---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout
  title="Blog"
  description="Technical articles and insights about software development, web technologies, and programming. Sharing knowledge on modern frameworks, tools, and best practices."
>
  <main class="max-w-2xl mx-auto px-6 py-8">
    <div class="space-y-8">
      {
        sortedPosts.map((post) => (
          <article class="">
            <div class="flex items-baseline justify-between gap-x-4">
              <h2 class="text-2xl">
                <a
                  href={`/blog/${post.slug}/`}
                  class="hover:text-brand-primary"
                >
                  {post.data.title}
                </a>
              </h2>
              <time datetime={post.data.date} class="text-gray-500 text-sm shrink-0">
                {new Date(post.data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</Layout>
