---
interface Props {
	currentPath: string;
	variant?: "default" | "fluid";
}

const { currentPath, variant = "default" } = Astro.props;
const isFluid = variant === "fluid";

const navItems = [
	{
		href: "/blog/",
		label: "Blog",
	},
	{
		href: "/projects/",
		label: "Projects",
	},
	{
		href: "/now/",
		label: "Now",
	},
];

function isActiveSection(itemHref: string, currentPath: string): boolean {
	return currentPath.startsWith(itemHref);
}
---

<nav class:list={["site-header", isFluid ? "site-header--fluid" : "max-w-2xl mx-auto px-6 py-8"]}>
	<div class:list={[isFluid ? "site-header__inner" : "flex items-baseline justify-between"]}>
		<a
			href="/"
			class:list={[
				isFluid ? "site-header__title" : "text-xl text-brand-primary hover:text-gray-800 transition-colors",
			]}
		>
			Yuval Adam
		</a>
		<ul class:list={[isFluid ? "site-header__nav" : "flex gap-6 items-baseline"]}>
			{
				navItems.map((item) => (
					<li>
						<a
							href={item.href}
							class:list={[
								isFluid ? "site-header__link" : "text-xl text-brand-primary hover:text-brand-primary/70 transition-colors duration-200",
								isActiveSection(item.href, currentPath) && "site-header__link--active",
							]}
						>
							{item.label}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</nav>
