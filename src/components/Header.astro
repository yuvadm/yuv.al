---
interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
	{
		href: "/blog/",
		label: "Blog",
		activeColor: "text-brand-primary",
		hoverColor: "hover:text-brand-primary",
	},
	{
		href: "/projects/",
		label: "Projects",
		activeColor: "text-brand-primary",
		hoverColor: "hover:text-brand-primary",
	},
	{
		href: "/now/",
		label: "Now",
		activeColor: "text-brand-primary",
		hoverColor: "hover:text-brand-primary",
	},
];

function isActiveSection(itemHref: string, currentPath: string): boolean {
	return currentPath.startsWith(itemHref);
}
---

<nav class="max-w-2xl mx-auto px-6 py-8">
	<div class="flex items-baseline justify-between">
		<a
			href="/"
			class="text-xl text-brand-primary hover:text-gray-800 transition-colors"
		>
			Yuval Adam
		</a>
		<ul class="flex gap-6 items-baseline">
			{
				navItems.map((item) => (
					<li>
						<a
							href={item.href}
							class="text-xl text-brand-primary hover:text-brand-primary/70 transition-colors duration-200"
						>
							{item.label}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</nav>
